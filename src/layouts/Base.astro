---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import social from "@/config/social.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import { AstroFont } from "astro-font";
import { ClientRouter } from "astro:transitions";
import { join } from "node:path";
import CookieConsent from "@/components/cookies/CookieConsent.astro";

// font families
const pf = theme.fonts.font_family.primary;
const sf = theme.fonts.font_family.secondary;

let fontPrimary, fontSecondary;
if (theme.fonts.font_family.primary) {
  fontPrimary = theme.fonts.font_family.primary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;.]+/gi, "");
}
if (theme.fonts.font_family.secondary) {
  fontSecondary = theme.fonts.font_family.secondary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;.]+/gi, "");
}

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  excerpt?: string;
  image?: string;
  image_alt?: string;
  noindex?: boolean;
  canonical?: string;
  type?: "website" | "article";
  published_date?: string | Date;
  modified_date?: string | Date;
  author?: { name?: string; url?: string };
  keywords?: string[];
  breadcrumbs?: Array<{ name: string; item: string }>;
}

const {
  title,
  meta_title,
  description,
  excerpt,
  image,
  image_alt,
  noindex,
  canonical,
  type = "website",
  published_date,
  modified_date,
  author,
  keywords,
  breadcrumbs,
} = Astro.props;

const siteUrl = config.site.base_url;

// Strip tracking params from canonical
const TRACKING_PARAMS = new Set([
  "utm_source",
  "utm_medium",
  "utm_campaign",
  "utm_content",
  "utm_term",
  "gclid",
  "fbclid",
  "msclkid",
  "mc_cid",
  "mc_eid",
  "ref",
  "ref_src",
  "yclid",
]);

function buildCanonical(): string {
  if (canonical) return canonical;
  const url = new URL(Astro.url.pathname, siteUrl);
  for (const param of TRACKING_PARAMS) url.searchParams.delete(param);
  return url.href.replace(/\?$/, "");
}

const canonicalURL = buildCanonical();

// Description fallback chain: description → excerpt → meta_description
const resolvedDescription = plainify(
  description || excerpt || config.metadata.meta_description,
);

const resolvedTitle = plainify(meta_title || title || config.site.title);

const ogImageUrl = `${siteUrl}${image || config.metadata.meta_image}`;
const ogImageAlt = image_alt || resolvedTitle;

const pubDate = published_date ? new Date(published_date).toISOString() : null;
const modDate = modified_date ? new Date(modified_date).toISOString() : pubDate;

// Build JSON-LD @graph per route
const orgId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;
const pageId = `${canonicalURL}#webpage`;
const articleId = `${canonicalURL}#article`;
const imageId = `${canonicalURL}#primaryimage`;

const sameAs = social.main.map((s) => s.link);

const graph: Record<string, unknown>[] = [
  {
    "@type": "Organization",
    "@id": orgId,
    name: "Drenpos",
    url: siteUrl,
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}${config.site.logo}`,
      width: Number(config.site.logo_width),
      height: Number(config.site.logo_height),
    },
    description:
      "Plataforma ERP SaaS modular para pymes y autónomos en España. Gestión de inventario, ventas, facturación electrónica Verifactu y control horario.",
    sameAs,
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "sales",
      url: `${siteUrl}/contact`,
      availableLanguage: ["Spanish", "es"],
    },
    areaServed: { "@type": "Country", name: "España" },
    knowsAbout: [
      "ERP",
      "Facturación electrónica",
      "Verifactu",
      "Control horario",
      "TPV",
      "Gestión de inventario",
      "Software para pymes",
    ],
    publishingPrinciples: `${siteUrl}/legal/aviso-legal`,
    copyrightHolder: { "@id": orgId },
    copyrightYear: new Date().getFullYear(),
  },
  {
    "@type": "SoftwareApplication",
    "@id": `${siteUrl}/#software`,
    name: "Drenpos ERP",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: siteUrl,
    description:
      "ERP SaaS modular para pymes españolas. Incluye almacén multialmacén, TPV, facturación electrónica con Verifactu (AEAT), control horario laboral y módulo médico. Sin costes por uso. Soporte humano incluido.",
    offers: {
      "@type": "Offer",
      priceCurrency: "EUR",
      description: "Suscripción mensual plana sin costes adicionales por uso",
      url: `${siteUrl}/pricing`,
    },
    provider: { "@id": orgId },
    featureList: [
      "Gestión de inventario multialmacén",
      "TPV (Terminal Punto de Venta)",
      "Facturación electrónica Verifactu",
      "Control horario laboral",
      "Gestión de pedidos y albaranes",
      "Trazabilidad de lotes",
      "Módulo sector médico",
      "Soporte humano incluido",
    ],
  },
  {
    "@type": "WebSite",
    "@id": websiteId,
    url: siteUrl,
    name: "Drenpos",
    description:
      "Ecosistema de gestión empresarial modular para pymes en España",
    publisher: { "@id": orgId },
    inLanguage: "es-ES",
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${siteUrl}/blog/?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@type": "WebPage",
    "@id": pageId,
    url: canonicalURL,
    name: resolvedTitle,
    description: resolvedDescription,
    isPartOf: { "@id": websiteId },
    inLanguage: "es-ES",
    ...(image && { primaryImageOfPage: { "@id": imageId } }),
    ...(modDate && { dateModified: modDate }),
    ...(pubDate && { datePublished: pubDate }),
  },
];

if (image) {
  graph.push({
    "@type": "ImageObject",
    "@id": imageId,
    url: ogImageUrl,
    contentUrl: ogImageUrl,
    caption: ogImageAlt,
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  graph.push({
    "@type": "BreadcrumbList",
    "@id": `${canonicalURL}#breadcrumb`,
    itemListElement: breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.name,
      item: b.item.startsWith("http") ? b.item : `${siteUrl}${b.item}`,
    })),
  });
}

if (type === "article" && pubDate) {
  graph.push({
    "@type": "BlogPosting",
    "@id": articleId,
    mainEntityOfPage: { "@id": pageId },
    headline: resolvedTitle,
    description: resolvedDescription,
    datePublished: pubDate,
    dateModified: modDate || pubDate,
    inLanguage: "es-ES",
    isPartOf: { "@id": websiteId },
    publisher: { "@id": orgId },
    ...(image && { image: { "@id": imageId } }),
    ...(keywords && keywords.length > 0 && { keywords: keywords.join(", ") }),
    ...(author?.name && {
      author: {
        "@type": "Person",
        name: author.name,
        ...(author.url && { url: author.url }),
      },
    }),
    url: canonicalURL,
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---

<!doctype html>
<html lang="es">
  <head>
    <CookieConsent />
    <script is:inline>
      (function (w, d) {
        w.dataLayer = w.dataLayer || [];
        w.gtag =
          w.gtag ||
          function () {
            w.dataLayer.push(arguments);
          };

        // Consent Mode v2: DENEGADO por defecto (cookieless)
        w.gtag("consent", "default", {
          ad_storage: "denied",
          ad_user_data: "denied",
          ad_personalization: "denied",
          analytics_storage: "denied",
        });

        // Cargar GTM (respetará el consentimiento)
        w.dataLayer.push({ "gtm.start": Date.now(), event: "gtm.js" });
        var f = d.getElementsByTagName("script")[0],
          j = d.createElement("script");
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=GTM-PDNNFZ98";
        f.parentNode.insertBefore(j, f);
      })(window, document);
    </script>
    <meta name="msvalidate.01" content="1C54C04B0BDB8940EC2C717A0CAAE934" />
    <!-- favicon -->
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="clarity-astro" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css -->
    <AstroFont
      config={[
        {
          name: pf,
          src: [
            {
              style: "normal",
              weight: "400",
              path: join(process.cwd(), "public", "fonts", "Aptos.ttf"),
            },
            {
              style: "normal",
              weight: "500",
              path: join(process.cwd(), "public", "fonts", "Aptos-Display.ttf"),
            },
            {
              style: "normal",
              weight: "700",
              path: join(process.cwd(), "public", "fonts", "Aptos-Bold.ttf"),
            },
          ],
          preload: true,
          display: "swap",
          selector: "body",
          fallback: "sans-serif",
          cssVariable: "font-primary",
        },
        {
          name: sf,
          src: [
            {
              style: "normal",
              weight: "500",
              path: join(
                process.cwd(),
                "public",
                "fonts",
                "ClashGrotesk-Medium.woff2",
              ),
            },
          ],
          preload: false,
          display: "swap",
          selector: "body",
          fallback: "sans-serif",
          cssVariable: "font-secondary",
        },
      ]}
    />

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>{resolvedTitle}</title>

    <!-- canonical url (suppressed when noindex per Google guidance) -->
    {!noindex && <link rel="canonical" href={canonicalURL} />}
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- robots meta -->
    {
      noindex ? (
        <meta name="robots" content="noindex,nofollow" />
      ) : (
        <meta
          name="robots"
          content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
        />
      )
    }

    <!-- meta-description -->
    <meta name="description" content={resolvedDescription} />

    <ClientRouter />

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- RSS alternates -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Drenpos Blog"
      href={`${siteUrl}/rss.xml`}
    />

    <!-- Open Graph -->
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta
      property="og:type"
      content={type === "article" ? "article" : "website"}
    />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Drenpos" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {
      type === "article" && pubDate && (
        <meta property="article:published_time" content={pubDate} />
      )
    }
    {
      type === "article" && modDate && (
        <meta property="article:modified_time" content={modDate} />
      )
    }
    {
      type === "article" && author?.name && (
        <meta property="article:author" content={author.name} />
      )
    }

    <!-- Twitter card (twitter:title/description/image fall back to og:* automatically) -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Structured data: @graph per route -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="overflow-x-hidden">
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PDNNFZ98"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <TwSizeIndicator />
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      import AOS from "aos";
      import "aos/dist/aos.css";

      let scrollRef = 0;

      // Fix `not animating although in viewport` issue
      window.addEventListener("scroll", function () {
        scrollRef <= 10 ? scrollRef++ : AOS.refresh();
      });

      function aosInit() {
        AOS.init({
          duration: 450,
          offset: 100,
          once: true,
        });
      }

      function scriptInit() {
        // Dropdown Menu Toggler For Mobile
        // ----------------------------------------
        const dropdownMenuToggler: NodeListOf<HTMLElement> =
          document.querySelectorAll(".nav-dropdown > .nav-link");

        dropdownMenuToggler.forEach((toggler) => {
          toggler?.addEventListener("click", (e: Event) => {
            const target = e.target as HTMLElement;
            target && target.parentElement?.classList.toggle("active");
          });
        });
      }

      document.addEventListener("astro:page-load", () => {
        scriptInit();
        aosInit();
      });
    </script>
  </body>
</html>
