---
// Safely access Clerk locals. On prerendered pages (export const prerender = true)
// the Clerk middleware has not run, so Astro.locals.auth is undefined.
// Default to the logged-out view in that case — bots don't sign in anyway.
let isAuthenticated = false;
let user: any = null;
let userImg: string | null = null;

if (typeof Astro.locals.auth === "function") {
  try {
    const auth = Astro.locals.auth();
    isAuthenticated = !!auth?.isAuthenticated;
    if (isAuthenticated && typeof Astro.locals.currentUser === "function") {
      user = await Astro.locals.currentUser();
      userImg = user?.imageUrl || null;
      const externalAccount = user?.externalAccounts?.[0];
      if (externalAccount?.imageUrl) {
        userImg = externalAccount.imageUrl;
      }
    }
  } catch {
    // Prerender or environment without Clerk runtime — fall through to logged-out.
  }
}
---

{user ? (
  <a
    href="https://contract.drenpos.com/home"
    class="flex items-center gap-2 hover:opacity-80 transition"
  >
    <img
      src={userImg}
      alt={user.fullName || 'Usuario'}
      class="w-10 h-10 rounded-full border-2 border-gray-300"
    />
  </a>
) : (
  <a
    href="https://contract.drenpos.com/auth"
    class="btn-primary"
  >
    Iniciar sesión
  </a>
)}
