---
import DynamicIcon from "@/helpers/DynamicIcon";

const {
  title = "¿Listo para optimizar tu negocio?",
  description = "Descubre cómo Drenpos puede ayudarte a gestionar tu empresa de forma más eficiente",
} = Astro.props;
---

<div
  class="mt-16 bg-gradient-to-r from-primary/10 to-primary/5 rounded-3xl p-8 md:p-12 border border-primary/20"
>
  <div class="text-center max-w-3xl mx-auto">
    <h3 class="text-2xl md:text-3xl font-bold mb-4">{title}</h3>
    <p class="text-lg text-text-dark/70 mb-8">{description}</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="/contact"
        class="btn btn-primary inline-flex items-center gap-2 group"
      >
        Contacta con nosotros
        <span class="icon-wrapper">
          <span class="icon">
            <DynamicIcon icon="FaArrowRight" />
          </span>
          <span class="icon" aria-hidden="true">
            <DynamicIcon icon="FaArrowRight" />
          </span>
        </span>
      </a>

      <a
        href="/pricing"
        class="btn btn-outline-primary inline-flex items-center gap-2"
      >
        Ver precios
      </a>
    </div>

    <p class="text-sm text-text-dark/60 mt-6">
      ¿Tienes dudas? Estamos aquí para ayudarte
    </p>
  </div>
</div>
