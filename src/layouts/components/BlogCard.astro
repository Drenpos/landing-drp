---
import config from "@/config/config.json";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify } from "@/lib/utils/textConverter";
import ImageMod from "./ImageMod.astro";

const {
  summary_length,
  blog_folder: defaultBlogFolder,
}: { summary_length: number; blog_folder: string } = config.settings;
const { data, blog_folder_int } = Astro.props;
const blog_folder = blog_folder_int || defaultBlogFolder;
const { title, image, date, categories } = data.data;
---

<div
  class="bg-body border border-dark/10 rounded-3xl p-4 min-h-full hover:shadow-2xl hover:border-primary/20 transition-all duration-300 group"
>
  <a href={`/${blog_folder}/${data.id.replace(".md", "")}`} class="block">
    <div class="relative overflow-hidden rounded-2xl mb-4">
      {
        image && (
          <ImageMod
            class="w-full h-[280px] object-cover object-center group-hover:scale-110 transition duration-700"
            src={image}
            alt={title}
            width={445}
            height={280}
            format="webp"
          />
        )
      }

      {
        categories && categories.length > 0 && (
          <div class="absolute top-3 left-3 flex flex-wrap gap-2">
            {categories.slice(0, 2).map((category: string) => (
              <span class="bg-primary/90 backdrop-blur-sm text-white rounded-full px-3 py-1 text-xs font-medium">
                {humanize(category)}
              </span>
            ))}
          </div>
        )
      }
    </div>

    <div class="px-2">
      {
        date && (
          <p class="text-text-dark/60 text-sm mb-3 flex items-center gap-2">
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            {dateFormat(date)}
          </p>
        )
      }

      <h4 class="my-3 h5 group-hover:text-primary transition-colors">
        {title}
      </h4>

      <p class="text-text-dark/70 line-clamp-3 mb-4">
        {plainify(data.body?.slice(0, Number(summary_length)))}
      </p>

      <div
        class="flex items-center text-primary font-medium text-sm group-hover:gap-3 transition-all"
      >
        Leer más
        <svg
          class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </div>
    </div>
  </a>
</div>
