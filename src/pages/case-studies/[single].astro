---
export const prerender = true;

import Base from "@/layouts/Base.astro";
import CaseStudySingle from "@/layouts/CaseStudySingle.astro";
import { getCollection } from "astro:content";
import CallToAction from "@/partials/CallToAction.astro";

export async function getStaticPaths() {
  const items = await getCollection("case-studies", ({ id, data }) =>
    !data.draft && id !== "-index",
  );
  return items.map((item) => ({
    params: { single: item.id },
    props: { caseStudy: item },
  }));
}

const { caseStudy } = Astro.props;
const { title, meta_title, description, image, date, author } = caseStudy.data;
const breadcrumbs = [
  { name: "Inicio", item: "/" },
  { name: "Casos de éxito", item: "/case-studies" },
  { name: title, item: `/case-studies/${caseStudy.id}` },
];
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
  image_alt={title}
  type="article"
  published_date={date}
  modified_date={date}
  author={author && { name: author.name }}
  breadcrumbs={breadcrumbs}
>
  <CaseStudySingle post={caseStudy} />
  <CallToAction />
</Base>
