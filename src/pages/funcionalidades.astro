---
export const prerender = true;
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import FeaturePowerSection from "@/partials/FeaturePowerSection.astro";
import PageHeader from "@/partials/PageHeader.astro";
---

<Base
  title="Funcionalidades Drenpos"
  meta_title="Funcionalidades avanzadas de Drenpos ERP · Comunicación y Trazabilidad"
  description="Envío de documentos por QR o email con templates personalizados, trazabilidad total de stock por lotes y caducidades, reportes automáticos y control de accesos. Todo integrado en Drenpos."
>
  <PageHeader
    title="Funcionalidades que marcan la diferencia"
    description="Más allá del TPV y la facturación. Drenpos incluye herramientas avanzadas que automatizan lo que antes hacías a mano —o que directamente no podías hacer."
  />

  <div class="section-up pb-0">
    <FeaturePowerSection />
  </div>

  <CallToAction />
</Base>
