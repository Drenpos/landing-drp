              </div>
              <div class="rounded-2xl p-5 text-center" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
                <p class="text-2xl font-bold mb-1" style="color: #f9b27c;">100%</p>
                <p class="text-xs" style="color: rgba(255,255,255,0.7);">Trazabilidad origen-destino</p>
              </div>
              <div class="rounded-2xl p-5 text-center" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
