                <p class="text-2xl font-bold mb-1" style="color: #f9b27c;">Auditoría</p>
                <p class="text-xs" style="color: rgba(255,255,255,0.7);">Histórico completo de movimientos</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

