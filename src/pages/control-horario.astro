---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import PageHeader from "@/partials/PageHeader.astro";
---

<Base
  title="Control Horario · Drenpos"
  meta_title="Control Horario con Drenpos ERP"
  description="Gestión y control horario integrado en tu sistema Drenpos. Próximamente."
>
  <PageHeader
    title="Control Horario"
    description="Próximamente. Estamos preparando todo para contarte cómo Drenpos gestiona los horarios de tu equipo."
  />

  <div class="section-up pb-0">
    <section class="section pt-0">
      <div class="container">
        <div class="row justify-center">
          <div class="col-10 lg:col-6 text-center" data-aos="fade-up-sm">
            <div
              class="inline-flex items-center justify-center w-20 h-20 rounded-full mb-8 text-4xl"
              style="background: rgba(121,27,70,0.08);"
            >
              ⏱️
            </div>
            <h2 class="h3 font-bold mb-4">En construcción</h2>
            <p class="text-lg mb-8" style="color: rgba(16,25,40,0.65);">
              Estamos preparando la sección de Control Horario. Vuelve pronto para ver todas las funcionalidades.
            </p>
            <a href="/funcionalidades" class="btn btn-dark">
              Ver otras funcionalidades
              <span class="icon-wrapper">
                <span class="icon">
                  <svg width="19" height="12" viewBox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12.5 1L17.5 6L12.5 11M1.5 6H17.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="icon" aria-hidden="true">
                  <svg width="19" height="12" viewBox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12.5 1L17.5 6L12.5 11M1.5 6H17.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <CallToAction />
</Base>
