---
export const prerender = true;
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";

// ════════════════════════════════════════════════════════════════════════
//  Control horario · landing dedicada (optimizada SEO 2026)
//  Imágenes UI:   /public/images/funcionalidades/control-horario/
//    01-gestion-personal.png · 02-gestion-manager.png · 03-reporte-resumen.png
//    04-reporte-trazabilidad.png · 05-conceptos.png · 06-calendario-laboral.png
//    07-calendario-asignacion.png · 08-widget-rapido.png
//  Imágenes HARDWARE (reemplazar placeholders por fotos reales):
//    hardware/01-dispositivo-lector-rfid.png
//    hardware/02-llaveros-personalizados.png
//    hardware/03-tarjetas-qr.png
//    hardware/04-hardware-conjunto.png
// ════════════════════════════════════════════════════════════════════════

const CANONICAL = "https://www.drenpos.com/control-horario";

const requisitos = [
  "Registro diario, individualizado y por trabajador",
  "Almacenamiento durante 4 años, accesible a la Inspección",
  "Inalterable: cada cambio queda registrado con autor y fecha",
  "Acceso del propio trabajador a su historial de fichajes",
  "Compatible con teletrabajo y empleados desplazados",
  "Exportable en formato legible para la autoridad laboral",
];

// Métodos de fichaje (tabla comparativa, buena para SEO/AEO)
const metodos = [
  {
    icon: "💻",
    name: "Web (ordenador)",
    desc: "Ficha desde el navegador en oficina o teletrabajo.",
    best: "Oficinas y administración",
  },
  {
    icon: "📱",
    name: "App PWA en el móvil",
    desc: "Instalable sin App Store ni Google Play. Solo la pantalla de fichaje.",
    best: "Comerciales y trabajo en campo",
  },
  {
    icon: "⚡",
    name: "Widget rápido",
    desc: "Ficha en un toque desde la pantalla de inicio, sin entrar al sistema.",
    best: "Inicio/parada frecuente",
  },
  {
    icon: "🔑",
    name: "Llavero RFID",
    desc: "Acerca el llavero al lector físico y ficha. Sin móvil ni pantalla.",
    best: "Almacenes, talleres, fábricas",
  },
  {
    icon: "📷",
    name: "Código QR personal",
    desc: "Cada empleado escanea su QR imprimible para iniciar o parar jornada.",
    best: "Hostelería, retail, eventos",
  },
];

// Casos de uso reales (long-tail + AEO)
const casos = [
  {
    tag: "Almacén · 20 empleados a turnos",
    title: "Fichaje sin tocar ningún sistema",
    body: "El administrador configura dos calendarios (turno mañana y turno tarde), asigna cada empleado a su turno, instala el lector físico en el almacén y entrega llaveros personalizados. Los empleados fichan al entrar y salir pasando el llavero. A fin de mes, el admin exporta el reporte de todo el equipo en un clic y lo envía a gestoría.",
    icon: "🏭",
  },
  {
    tag: "Equipo comercial en movilidad",
    title: "Fichar desde cualquier ubicación",
    body: "Cada comercial instala la app PWA en su móvil y ficha desde donde esté. El sistema registra la hora con sellado temporal inalterable: no se puede modificar sin dejar huella. El responsable ve los fichajes en tiempo real sin llamadas ni mensajes.",
    icon: "🚗",
  },
];

const faqs = [
  {
    q: "¿El registro horario es realmente obligatorio en 2026?",
    a: "Sí. Todas las empresas con empleados por cuenta ajena están obligadas a llevar un registro horario diario, individualizado e inalterable. La Inspección de Trabajo puede solicitarlo en cualquier momento y la falta de registro está tipificada como infracción grave, con sanciones de 625 € a 6.250 € por centro de trabajo.",
  },
  {
    q: "¿Qué es exactamente el control horario digital?",
    a: "Es el sistema que registra de forma fiable la hora de entrada y de salida de cada trabajador, conservando los datos de manera inalterable y accesible. A diferencia del papel o el Excel, un sistema digital como Drenpos garantiza que cada fichaje queda sellado con fecha, autor y trazabilidad, cumpliendo la normativa de registro de jornada.",
  },
  {
    q: "¿Sirve un Excel como sistema de fichaje?",
    a: "Hoy ya no es suficiente. Un Excel se puede modificar sin dejar rastro, no es inalterable y no permite acceso individualizado al trabajador. Drenpos cumple los requisitos legales por diseño: cada acción queda auditada y trazada.",
  },
  {
    q: "¿Pueden mis empleados fichar desde el móvil?",
    a: "Sí. Drenpos funciona desde ordenador y desde el móvil con una app PWA instalable sin tiendas de aplicaciones. Ideal para teletrabajo, comerciales o personal desplazado entre delegaciones.",
  },
  {
    q: "¿Cómo se ficha sin pantallas individuales por empleado?",
    a: "Ofrecemos un dispositivo físico propio que lee llaveros RFID personalizados o el QR personal de cada empleado. Pensado para almacenes, talleres, hostelería y retail. El fichaje se inicia o se detiene en cuanto se acerca el llavero o se escanea el QR, sin que el operario necesite móvil ni ordenador.",
  },
  {
    q: "¿Puedo comprar el dispositivo de fichaje sin contratar el sistema?",
    a: "Sí. El hardware de fichaje de Drenpos (lector RFID, llaveros personalizados y tarjetas QR) puede adquirirse como solución de control de presencia independiente. Si más adelante quieres el ecosistema completo, se integra sin perder ningún dato. Escríbenos para una propuesta a medida.",
  },
  {
    q: "¿Qué pasa si un empleado se olvida de fichar?",
    a: "El manager puede crear o corregir el fichaje desde su panel. Cada modificación queda registrada con autor, fecha y motivo en la tabla de trazabilidad, así el reporte sigue siendo válido frente a la Inspección.",
  },
  {
    q: "¿Puedo usar conceptos de fichaje propios de mi empresa?",
    a: "Sí. Puedes crear todos los conceptos que necesites (formación, visita cliente, comida, asuntos propios, etc.), definir si computan como jornada laboral o no, e incluso establecer límites diarios o semanales por concepto.",
  },
];

// Enlazado interno · control horario por ciudad (clúster local)
const ciudades = [
  { n: "Mérida", s: "software-control-horario-merida" },
  { n: "Badajoz", s: "software-control-horario-badajoz-2026" },
  { n: "Cáceres", s: "software-control-horario-caceres" },
  { n: "Plasencia", s: "software-control-horario-empresas-plasencia" },
  { n: "Don Benito", s: "software-control-horario-don-benito" },
  { n: "Almendralejo", s: "software-control-horario-almendralejo" },
  { n: "Villanueva de la Serena", s: "software-control-horario-villanueva-de-la-serena" },
  { n: "Montijo", s: "software-control-horario-montijo-2026" },
  { n: "Navalmoral de la Mata", s: "software-control-horario-navalmoral-de-la-mata" },
  { n: "Zafra", s: "software-control-horario-zafra" },
  { n: "Coria", s: "software-control-horario-coria" },
];

// Artículos relacionados (clúster temático)
const articulos = [
  { t: "Registro horario 2026: nuevos requisitos y cómo adaptarte", s: "registro-horario-2026-nuevos-requisitos-adaptacion" },
  { t: "Multas del registro horario 2026: lo que cuesta incumplir", s: "multas-registro-horario-2026-costo-incumplimiento" },
  { t: "Por qué Excel ya no sirve para el control horario", s: "por-que-excel-ya-no-sirve-control-horario-2026" },
  { t: "Fichar desde el móvil: ¿es legal en 2026?", s: "fichar-desde-el-movil-legal-2026" },
  { t: "Control horario en teletrabajo: cómo cumplir la ley", s: "control-horario-teletrabajo-cumplir-ley-2026" },
  { t: "Comparativa: mejor software de control horario para pymes", s: "comparativa-mejores-software-control-horario-pymes-2026" },
];

// ── Datos estructurados (JSON-LD) ──────────────────────────────────────
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: "https://www.drenpos.com/" },
    { "@type": "ListItem", position: 2, name: "Funcionalidades", item: "https://www.drenpos.com/funcionalidades" },
    { "@type": "ListItem", position: 3, name: "Control Horario", item: CANONICAL },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Drenpos · Control Horario",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, iOS, Android (PWA)",
  url: CANONICAL,
  description:
    "Software de control horario y registro de jornada para empresas. Fichaje por web, móvil (PWA), widget rápido, llavero RFID y código QR. Reportes inalterables listos para la Inspección de Trabajo. Hardware de fichaje propio diseñado por Drenpos.",
  offers: {
    "@type": "Offer",
    price: "1.09",
    priceCurrency: "EUR",
    description: "Módulo Fichajes desde 1,09 €/mes por usuario. Incluido en todos los planes Drenpos.",
    url: "https://www.drenpos.com/pricing",
  },
  featureList: [
    "Registro horario diario e individualizado",
    "Fichaje por web, móvil PWA, widget, RFID y QR",
    "Calendarios laborales y festivos por empleado",
    "Conceptos de fichaje personalizables",
    "Reportes y trazabilidad para Inspección de Trabajo",
    "Hardware de fichaje propio (lector RFID + llaveros + tarjetas QR)",
  ],
  provider: { "@type": "Organization", name: "Drenpos", url: "https://www.drenpos.com" },
};
---

<Base
  title="Control Horario y Registro de Jornada · Drenpos"
  meta_title="Software de Control Horario y Fichajes 2026 | Drenpos"
  description="Software de control horario para cumplir el registro de jornada 2026. Fichaje por web, móvil, QR y llavero RFID con hardware propio. Reportes listos para Inspección. Demo gratis."
  canonical={CANONICAL}
  image="/images/funcionalidades/control-horario/01-gestion-personal.png"
>
  <!-- Datos estructurados -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════════ -->
  <section class="section-sm pb-0 relative z-10 overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <img
        src="/images/grainy.svg"
        alt=""
        width="1440"
        height="900"
        class="w-full h-full object-cover opacity-[.08]"
      />
    </div>

    <div class="container relative z-10">
      <!-- Breadcrumb visible -->
      <nav aria-label="Migas de pan" class="mb-6 text-sm" style="color: rgba(16,25,40,0.55);">
        <a href="/" class="hover:text-primary">Inicio</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <a href="/funcionalidades" class="hover:text-primary">Funcionalidades</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-primary font-medium">Control Horario</span>
      </nav>

      <div class="row gx-0 gy-12 lg:gy-0 items-center">
        <div class="lg:col-6" data-aos="fade-up-sm">
          <span
            class="text-primary bg-primary/10 px-4 py-1.5 inline-flex items-center gap-2 rounded-full uppercase text-sm font-medium mb-6"
          >
            <span class="w-2 h-2 rounded-full" style="background: #16a34a;" aria-hidden="true"></span>
            Registro de jornada · Ley 2026
          </span>

          <h1 class="mb-5 text-h3 lg:text-h1 font-bold leading-tight">
            Software de <span class="text-primary">control horario</span> para cumplir la ley sin Excel ni multas
          </h1>
          <p class="text-lg mb-8 max-w-xl" style="color: rgba(16,25,40,0.72);">
            Drenpos digitaliza el registro de jornada de tu equipo con la
            trazabilidad que exige la Inspección de Trabajo. Fichaje por web,
            móvil, widget, código QR o llavero RFID con hardware propio. Cumples
            la normativa desde el primer día.
          </p>

          <ul class="flex flex-wrap gap-4 mb-10">
            <li data-aos="fade-up-sm" data-aos-delay="100">
              <a href="/contact" class="btn btn-dark">
                Pedir demo gratuita
                <span class="icon-wrapper">
                  <span class="icon">
                    <svg width="19" height="12" viewBox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12.5 1L17.5 6L12.5 11M1.5 6H17.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span class="icon" aria-hidden="true">
                    <svg width="19" height="12" viewBox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12.5 1L17.5 6L12.5 11M1.5 6H17.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </span>
                </span>
              </a>
            </li>
            <li data-aos="fade-up-sm" data-aos-delay="150">
              <a href="#hardware" class="btn btn-light">Ver el dispositivo de fichaje</a>
            </li>
          </ul>

          <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm" style="color: rgba(16,25,40,0.62);">
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 text-white text-[10px] font-bold" style="background: #16a34a;">✓</span>
              Listo para Inspección de Trabajo
            </div>
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 text-white text-[10px] font-bold" style="background: #16a34a;">✓</span>
              Web + móvil + RFID
            </div>
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 text-white text-[10px] font-bold" style="background: #16a34a;">✓</span>
              Sin permanencia
            </div>
          </div>
        </div>

        <div class="lg:col-6" data-aos="fade-up-sm" data-aos-delay="200">
          <div class="relative px-4 lg:px-0 pt-10 pb-10">
            <div class="absolute -top-10 -right-10 w-80 h-80 rounded-full blur-3xl -z-10 pointer-events-none" style="background: rgba(121,27,70,0.10);"></div>
            <div class="absolute bottom-0 left-0 w-56 h-56 rounded-full blur-2xl -z-10 pointer-events-none" style="background: rgba(211,167,118,0.12);"></div>

            <div class="rounded-2xl overflow-hidden relative z-10" style="box-shadow: 0 30px 80px rgba(0,0,0,0.18), 0 6px 20px rgba(0,0,0,0.08); border: 1px solid rgba(16,25,40,0.08);">
              <img
                src="/images/funcionalidades/control-horario/01-gestion-personal.png"
                alt="Panel de control horario de Drenpos con gráfico de dedicación y fichajes del día"
                width="720"
                height="480"
                class="w-full h-auto block"
                fetchpriority="high"
              />
            </div>

            <div class="absolute -bottom-5 -left-2 lg:-left-8 rounded-2xl px-4 py-3 flex items-center gap-3" style="background: white; box-shadow: 0 8px 32px rgba(0,0,0,0.13); border: 1px solid rgba(16,25,40,0.07);" data-aos="zoom-in-up-sm" data-aos-delay="500">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-base flex-shrink-0 font-bold animate-pulse" style="background: #dcfce7; color: #16a34a;">●</div>
              <div>
                <p class="text-xs font-bold text-dark">Fichando ahora</p>
                <p class="text-xs" style="color: #9ca3af;">06h 42min · jornada activa</p>
              </div>
            </div>

            <div class="absolute -top-5 -right-2 lg:-right-6 rounded-2xl px-4 py-3 flex items-center gap-2.5" style="background: white; box-shadow: 0 8px 32px rgba(0,0,0,0.13); border: 1px solid rgba(16,25,40,0.07);" data-aos="fade-up-sm" data-aos-delay="450">
              <div class="w-8 h-8 rounded-xl flex items-center justify-center text-lg flex-shrink-0" style="background: #fef3c7;">⚖️</div>
              <div>
                <p class="text-xs font-bold text-dark">100% legal</p>
                <p class="text-xs" style="color: #9ca3af;">Registro 2026</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       DEFINICIÓN CITABLE (AEO / featured snippet)
  ═══════════════════════════════════════════════════════════════════ -->
  <section class="section-sm pb-0">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-9 text-center" data-aos="fade-up-sm">
          <h2 class="h4 font-bold mb-4">¿Qué es un software de control horario?</h2>
          <p class="text-lg leading-relaxed" style="color: rgba(16,25,40,0.72);">
            Un <strong>software de control horario</strong> es una herramienta
            digital que registra la entrada y salida de cada trabajador de forma
            fiable, individualizada e inalterable, y conserva esos datos durante
            cuatro años para cumplir la ley de registro de jornada. Drenpos
            permite fichar desde el ordenador, el móvil, un widget rápido, un
            código QR o un llavero RFID, y genera reportes auditables listos
            para la Inspección de Trabajo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       BANNER LEGAL: la urgencia
  ═══════════════════════════════════════════════════════════════════ -->
  <section class="section-sm">
    <div class="container">
      <div class="rounded-[28px] p-8 lg:p-12 relative overflow-hidden" style="background: linear-gradient(135deg, rgba(121,27,70,0.08) 0%, rgba(211,167,118,0.10) 100%); border: 1px solid rgba(16,25,40,0.06);" data-aos="fade-up-sm">
        <div class="row gx-0 gy-8 lg:gy-0 items-center">
          <div class="lg:col-7 lg:pe-10">
            <span class="text-primary bg-white/70 px-3 py-1 inline-block rounded-full uppercase text-xs font-medium mb-5 tracking-wide">Lo que dice la ley</span>
            <h2 class="h4 mb-4 font-bold leading-tight">
              El registro horario no es opcional.<br />
              <span class="text-primary">Lo que está en juego son multas reales.</span>
            </h2>
            <p class="text-lg mb-0 leading-relaxed" style="color: rgba(16,25,40,0.72);">
              Llevar el registro en papel, en Excel o de forma incompleta es
              motivo de sanción. La Inspección de Trabajo puede pedir tu registro
              horario en cualquier momento y debes presentarlo individualizado,
              diario, inalterable y conservado durante 4 años.
            </p>
          </div>
          <div class="lg:col-5">
            <div class="grid grid-cols-3 gap-4">
              <div class="rounded-2xl p-5 text-center" style="background: white; box-shadow: 0 4px 16px rgba(0,0,0,0.05);">
                <p class="text-3xl font-bold text-primary mb-1">€625</p>
                <p class="text-xs uppercase tracking-wide" style="color: rgba(16,25,40,0.55);">Multa mínima</p>
              </div>
              <div class="rounded-2xl p-5 text-center" style="background: white; box-shadow: 0 4px 16px rgba(0,0,0,0.05);">
                <p class="text-3xl font-bold text-primary mb-1">€6.250</p>
                <p class="text-xs uppercase tracking-wide" style="color: rgba(16,25,40,0.55);">Por centro</p>
              </div>
              <div class="rounded-2xl p-5 text-center" style="background: white; box-shadow: 0 4px 16px rgba(0,0,0,0.05);">
                <p class="text-3xl font-bold text-primary mb-1">4 años</p>
                <p class="text-xs uppercase tracking-wide" style="color: rgba(16,25,40,0.55);">Conservación</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       FEATURE 1 · Mis fichajes (vista empleado)
  ═══════════════════════════════════════════════════════════════════ -->
  <section class="section pt-0 overflow-hidden">
    <div class="container">
      <div class="row gx-0 gy-14 lg:gy-0 items-center mb-24 lg:mb-32">
        <div class="lg:col-6 lg:pe-8" data-aos="fade-up-sm" data-aos-delay="100">
          <div class="relative px-6 lg:px-0 pt-10 pb-10">
            <div class="absolute -top-10 -left-10 w-72 h-72 rounded-full blur-3xl -z-10 pointer-events-none" style="background: rgba(121,27,70,0.08);"></div>
            <div class="rounded-2xl overflow-hidden" style="box-shadow: 0 24px 64px rgba(0,0,0,0.13), 0 4px 16px rgba(0,0,0,0.07); border: 1px solid rgba(16,25,40,0.08);">
              <img src="/images/funcionalidades/control-horario/01-gestion-personal.png" alt="Pantalla personal de fichajes con gráfico de dedicación del empleado" width="640" height="420" class="w-full h-auto block" loading="lazy" />
            </div>
          </div>
        </div>

        <div class="lg:col-6 lg:ps-16" data-aos="fade-up-sm" data-aos-delay="300">
          <span class="text-primary bg-primary/10 px-3 py-1 inline-block rounded-full uppercase text-sm font-medium mb-6">Para empleados</span>
          <h2 class="h4 mb-5 font-bold leading-tight">
            Cada persona, su panel.<br />
            <span class="text-primary">Fichar y desfichar en un clic.</span>
          </h2>
          <p class="text-lg mb-8 leading-relaxed" style="color: rgba(16,25,40,0.72);">
            Tus empleados acceden a su propio panel desde cualquier dispositivo:
            ven sus fichajes del día, semana y mes, inician o detienen la jornada
            con un solo botón y exportan su informe sin tener que pedírselo a
            nadie.
          </p>

          <div class="flex flex-col gap-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 text-xl leading-none pt-1">⏱️</div>
              <div>
                <p class="font-semibold text-text-dark mb-1">Fichaje en un clic</p>
                <p class="text-sm" style="color: rgba(16,25,40,0.62);">Inicia y detén la jornada desde la propia pantalla, sin formularios ni pasos intermedios.</p>
