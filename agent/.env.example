# ─── LLM provider ───────────────────────────────────────────────────────────
# 'ollama' (local, default) | 'openai' (cualquier endpoint OpenAI-compatible)
LLM_PROVIDER=ollama

# Timeouts comunes a ambos providers (en ms)
LLM_TIMEOUT=180000          # análisis, síntesis (cortos)
LLM_GEN_TIMEOUT=600000      # generación de artículos completos

# ─── Ollama (provider local) ────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:35b
# Si defines estos, machacan los LLM_*_TIMEOUT de arriba
# OLLAMA_TIMEOUT=180000
# OLLAMA_GEN_TIMEOUT=600000

# ─── OpenAI-compatible (cuando LLM_PROVIDER=openai) ─────────────────────────
# Funciona con cualquier endpoint que implemente /v1/chat/completions:
#   https://api.openai.com/v1                    (OpenAI)
#   https://openrouter.ai/api/v1                 (OpenRouter)
#   https://api.together.xyz/v1                  (Together)
#   https://api.groq.com/openai/v1               (Groq)
#   https://api.deepseek.com/v1                  (DeepSeek)
#   https://api.mistral.ai/v1                    (Mistral)
#   https://<resource>.openai.azure.com/...      (Azure OpenAI)
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_ORG=                # opcional: header OpenAI-Organization
# OPENAI_PROJECT=            # opcional: header OpenAI-Project
# OPENAI_TIMEOUT=180000
# OPENAI_GEN_TIMEOUT=600000

# ─── Research config ────────────────────────────────────────────────────────
RESEARCH_MAX_RESULTS=5
SEARCH_ENGINE=duckduckgo   # 'duckduckgo' | 'serp'
SERP_API_KEY=              # Opcional, si usas SerpAPI
PAGE_TIMEOUT_MS=12000

# ─── Git config ─────────────────────────────────────────────────────────────
GIT_AUTO_PUSH=false
GIT_BRANCH=main

# ─── Author (opcional, sobreescribe el default) ─────────────────────────────
AUTHOR_NAME=Alonso Bermejo Pérez
AUTHOR_DESIGNATION=CEO & Founder
AUTHOR_AVATAR=/images/alonso.jpg

# ─── Debug ──────────────────────────────────────────────────────────────────
DEBUG=false
