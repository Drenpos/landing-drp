# Ollama config
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:35b
OLLAMA_TIMEOUT=180000        # Timeout para llamadas cortas (análisis, síntesis) — ms
OLLAMA_GEN_TIMEOUT=600000   # Timeout para generación de artículos (modelos 35B+ tardan 5-10 min)

# Research config
RESEARCH_MAX_RESULTS=5
SEARCH_ENGINE=duckduckgo   # 'duckduckgo' | 'serp'
SERP_API_KEY=              # Opcional, si usas SerpAPI
PAGE_TIMEOUT_MS=12000

# Git config
GIT_AUTO_PUSH=false
GIT_BRANCH=main

# Author (opcional, sobreescribe el default)
AUTHOR_NAME=Alonso Bermejo Pérez
AUTHOR_DESIGNATION=CEO & Founder
AUTHOR_AVATAR=/images/alonso.jpg

# Debug
DEBUG=false
