# =============================================================================
# VARIABLES DE ENTORNO REQUERIDAS - Landing DRP
# =============================================================================
# Copia este archivo como .env y configura los valores apropiados
# NUNCA subas el archivo .env al repositorio

# -----------------------------------------------------------------------------
# Astro Configuration
# -----------------------------------------------------------------------------
# URL base del sitio (usada para generar sitemap y URLs canónicas)
SITE=https://tudominio.com

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Clave pública de Clerk (seguro exponer en el cliente)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Clave secreta de Clerk (NUNCA exponer en el cliente)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# -----------------------------------------------------------------------------
# Google reCAPTCHA
# -----------------------------------------------------------------------------
# Site Key de reCAPTCHA (seguro exponer en el cliente)
PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Secret Key de reCAPTCHA (NUNCA exponer en el cliente)
# Nota: Esta se usa en el servidor/API para validar el token
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# -----------------------------------------------------------------------------
# Cloudflare Configuration (para desarrollo local)
# -----------------------------------------------------------------------------
# Estas variables se configuran en Cloudflare Dashboard para producción
# Para desarrollo local, puedes definirlas aquí
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_API_TOKEN=your_api_token
